#!/bin/bash -e

# If running the rails server then create or migrate existing database.
# MySQL on Railway may be waking from serverless sleep or slow DNS; db:prepare
# can fail with ETIMEDOUT (110) — retry until DB is reachable (within healthcheck window).
if [ "${1}" == "./bin/rails" ] && [ "${2}" == "server" ]; then
  max=60
  attempt=0
  until ./bin/rails db:prepare; do
    attempt=$((attempt + 1))
    if [ "${attempt}" -ge "${max}" ]; then
      echo "db:prepare failed after ${max} attempts; giving up."
      exit 1
    fi
    echo "db:prepare failed (attempt ${attempt}/${max}), retrying in 5s..."
    sleep 5
  done
fi

exec "${@}"
